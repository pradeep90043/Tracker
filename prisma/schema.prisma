// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model DailyEntry {
  id                 String   @id @default(uuid())
  userId             String
  date               String   // YYYY-MM-DD
  
  // DSA
  dsaHours           Float
  dsaProblemsSolved  Int
  dsaTopic           String
  
  // Backend
  backendHours       Float
  backendTopic       String
  
  // AI
  aiHours            Float
  aiTopic            String
  
  // Booleans
  projectWork        Boolean
  revision           Boolean
  deepWork           Boolean
  
  // Computed (stored for easier querying, though can be calculated)
  totalHours         Float
  score              Int
  performanceLevel   String
  passed             Boolean

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([userId, date])
}

model FailureLog {
  id          String   @id @default(uuid())
  userId      String
  date        String
  missedTask  String
  reason      String
  rootCause   String
  fixAction   String
  category    String

  createdAt   DateTime @default(now())
}

model WeeklyGoal {
  id                      String   @id @default(uuid())
  userId                  String
  weekStart               String   // ISO date of Monday
  weekEnd                 String
  dsaTopics               String
  backendTopics           String
  aiTopics                String
  projectGoal             String
  dsaTopicsCompleted      String
  backendTopicsCompleted  String
  aiTopicsCompleted       String
  projectGoalCompleted    Boolean

  createdAt               DateTime @default(now())

  @@unique([userId, weekStart])
}

model WeeklyReview {
  id             String   @id @default(uuid())
  userId         String
  weekStart      String
  weekEnd        String
  metGoals       Boolean
  whatWentWrong  String
  whatToImprove  String
  rating         Int
  createdAt      DateTime @default(now())

  @@unique([userId, weekStart])
}

model FocusSession {
  id              String   @id @default(uuid())
  userId          String
  date            String
  category        String
  durationMinutes Int
  completedAt     DateTime @default(now())
}

model NamasteDevSession {
  id             String   @id @default(uuid())
  userId         String
  token          String   @db.Text
  sessionToken   String   @db.Text
  lastUpdated    DateTime @default(now())
}

model ExternalStats {
  id             String   @id @default(uuid())
  userId         String
  platform       String   // e.g., "namastedev"
  data           Json     // Stores currentStreak, longestStreak, currentCourse, etc.
  lastSynced     DateTime @default(now())

  @@unique([userId, platform])
}
